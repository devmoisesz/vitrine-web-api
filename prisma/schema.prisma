generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum CollaboratorRole {
  PROPRIETARIO
  FUNCIONARIO
}

enum StatusStore {
  ATIVA
  INATIVA
}

enum StatusProduct {
  ATIVO
  INATIVO
}

enum StatusCart {
  ATIVO
  CONCLUIDO
}

model User {
  id          String @id @default(uuid())
  name        String
  email       String @unique
  password    String?
  role        UserRole @default(USER)

  collaborator Collaborator?
  addresses Address[]
  carts Cart[]
  orders Order[]

  @@map("users")
}

model Collaborator {
  id          String @id @default(uuid())
  userId      String @unique @map("user_id")
  storeId     String @map("store_id")
  role        CollaboratorRole @default(FUNCIONARIO)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("collaborators")
}

model Store {
  id                String @id @default(uuid())
  name              String
  slug              String @unique
  email             String? @unique
  description       String?
  whatsapp          String @unique
  cnpj              String? @unique
  cpf               String? @unique
  status            StatusStore @default(ATIVA)
  logo_image_url    String?
  storage_public_id String?
  createdAt    DateTime @default(now()) @map("created_at")

  collaborators Collaborator[]
  address Address?
  products Product[]
  cart Cart[]
  orders Order[]

  @@map("stores")
}

model Address {
  id           String   @id @default(uuid())
  label        String?
  userId       String?  @map("user_id")
  storeId      String?  @unique @map("store_id")
  cep          String?
  state        String
  city         String
  neighborhood String
  street       String?
  number       String?
  complement   String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  slug         String 
  description  String
  price        Decimal
  sizes        String[] @default([])
  stock        Int
  status       StatusProduct @default(ATIVO)
  storeId      String @map("store_id")
  categoryId   String @map("category_id")
  subcategoryId String @map("subcategory_id")
  createdAt    DateTime @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory SubCategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  products_images ProductImages[]
  cart_items CartItems[]
  tags  Tag[]

  @@unique([slug, storeId])
  @@index([storeId, subcategoryId])
  @@map("products")
}

model Tag {
  id           String   @id @default(uuid())
  name         String @unique

  products Product[]

  @@map("tags")
}

model ProductImages {
  id           String   @id @default(uuid())
  productId    String @map("product_id")
  image_url    String
  storage_public_id String
  is_main       Boolean
  createdAt     DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Category {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  createdAt    DateTime @default(now()) @map("created_at")

  products  Product[]
  subcategories SubCategory[]
  
  @@map("categories")
}

model SubCategory {
  id           String   @id @default(uuid())
  name         String 
  slug         String 
  categoryId   String @map("category_id")
  createdAt    DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, categoryId])
  @@unique([slug, categoryId])
  @@map("subcategories")
}

model Cart {
  id           String   @id @default(uuid())
  userId      String @map("user_id")
  storeId      String  @map("store_id")
  status       StatusCart @default(ATIVO)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  cart_items CartItems[]

  @@unique([userId, storeId])
  @@map("carts")
}

model CartItems {
  id           String   @id @default(uuid())
  cartId       String @map("cart_id")
  productId    String @map("product_id")
  quantity     Int
  priceAtPurchase Decimal @map("price_at_purchase")

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Order {
  id           String   @id @default(uuid())
  userId       String @map("user_id") 
  storeId      String @map("store_id")
  total        Decimal
  createdAt    DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  order_items OrderItems[]

  @@map("orders")
}

model OrderItems {
  id           String   @id @default(uuid())
  orderId      String @map("order_id")
  productName  String
  price        Decimal
  quantity     Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}